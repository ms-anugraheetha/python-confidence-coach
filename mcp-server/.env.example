# ─────────────────────────────────────────────────────────────────────────────
# Python Confidence Coach — MCP Server Environment Variables
# cp .env.example .env  then fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key used by the tools (explain, check, assess) via the
# OpenAI-compatible endpoint. Free tier: console.groq.com
GROQ_API_KEY=gsk_...                      # ← REQUIRED

# Model used inside tool calls.
GROQ_MODEL=llama-3.1-8b-instant           # ← OPTIONAL

# Host/port the MCP HTTP server listens on.
MCP_HOST=0.0.0.0                          # ← OPTIONAL
MCP_PORT=8001                             # ← OPTIONAL

# "development" | "production"
ENVIRONMENT=development                   # ← OPTIONAL

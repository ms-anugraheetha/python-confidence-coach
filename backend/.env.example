# ─────────────────────────────────────────────────────────────────────────────
# Python Confidence Coach — Backend Environment Variables
#
# SETUP:
#   cp .env.example .env
#   Fill in every value marked  ← REQUIRED
#   Values marked  ← OPTIONAL  have safe defaults already set in config.py
#
# NEVER commit .env to Git. It is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# "development" | "production" | "test"
# Controls log format, CORS strictness, and debug error messages.
ENVIRONMENT=development                                        # ← REQUIRED

# Full name shown in API docs (OpenAPI /docs)
APP_NAME="Python Confidence Coach"                             # ← OPTIONAL


# ── Security ──────────────────────────────────────────────────────────────────

# Used to sign JWT tokens. Must be long, random, and secret.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-before-running    # ← REQUIRED

# JWT algorithm. HS256 is standard for single-service auth.
ALGORITHM=HS256                                                # ← OPTIONAL

# How long access tokens live (minutes). 30 min is a safe default.
ACCESS_TOKEN_EXPIRE_MINUTES=30                                 # ← OPTIONAL

# How long refresh tokens live (days). 7 days is standard.
REFRESH_TOKEN_EXPIRE_DAYS=7                                    # ← OPTIONAL


# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL async connection string.
# Format: postgresql+asyncpg://user:password@host:port/dbname
#
# Local dev (Docker Compose default):
DATABASE_URL=postgresql+asyncpg://coach:coach@localhost:5432/confidence_coach  # ← REQUIRED

# Max connections in the pool. 10 is safe for a single-instance dev server.
# Increase for production based on your Postgres max_connections setting.
DB_POOL_SIZE=10                                                # ← OPTIONAL

# Extra overflow connections allowed during traffic spikes.
DB_MAX_OVERFLOW=20                                             # ← OPTIONAL


# ── AI — Groq ─────────────────────────────────────────────────────────────────

# Your Groq API key. Get it from https://console.groq.com
GROQ_API_KEY=gsk_...                                            # ← REQUIRED


# ── MCP Server ────────────────────────────────────────────────────────────────

# Base URL of the FastMCP server process (must include the /mcp path).
# In Docker Compose this will be http://mcp:8001/mcp
MCP_SERVER_URL=http://localhost:8001/mcp                       # ← REQUIRED

# Timeout in seconds for MCP tool calls.
# Claude tool calls can take 5–15s. 30s gives headroom.
MCP_TIMEOUT_SECONDS=30                                         # ← OPTIONAL


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# In production, replace with your actual Vercel URL.
# Example: https://confidence-coach.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000       # ← REQUIRED


# ── Google OAuth ──────────────────────────────────────────────────────────────

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Leave empty to disable Google Sign-In.
GOOGLE_CLIENT_ID=                                              # ← OPTIONAL


# ── Logging ───────────────────────────────────────────────────────────────────

# "DEBUG" | "INFO" | "WARNING" | "ERROR"
# DEBUG gives verbose output — useful locally, too noisy in production.
LOG_LEVEL=DEBUG                                                # ← OPTIONAL

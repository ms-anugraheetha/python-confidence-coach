# frontend/.env.example
#
# Copy to .env.local for local development that targets the Render backend.
# In production (Vercel), vercel.json rewrites /api/* so VITE_API_URL is
# not needed — leave it empty or omit it entirely.
#
# LOCAL DEV (against Render backend instead of local):
#   VITE_API_URL=https://coach-backend.onrender.com
#
# LOCAL DEV (against local backend — default, no override needed):
#   (leave this file empty; Vite proxy in vite.config.ts handles it)

VITE_API_URL=
